{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

ZEN_DIR="$HOME/.config/zen"
INI="$ZEN_DIR/profiles.ini"
SOURCE_CHROME="{{ .chezmoi.sourceDir }}/dot_config/zen/chrome"

if [ ! -f "$INI" ]; then
    echo "[zen-chrome-link] profiles.ini not found at $INI — skipping. Run again after Zen has been launched once."
    exit 0
fi

# Match the profile named "Default (release)" specifically 
PROFILE_PATH=$(awk -F'=' '
    /^\[/ {
        if (name == "Default (release)" && path != "" && !done) {
            print path
            done = 1
        }
        name=""; path=""
    }
    /^Name=/ { name=$2 }
    /^Path=/ { path=$2 }
    END {
        if (name == "Default (release)" && path != "" && !done) print path
    }
' "$INI")

if [ -z "$PROFILE_PATH" ]; then
    echo "[zen-chrome-link] Could not find profile named 'Default (release)' in $INI — skipping."
    exit 0
fi

PROFILE_DIR="$ZEN_DIR/$PROFILE_PATH"
TARGET_CHROME="$PROFILE_DIR/chrome"

if [ ! -d "$PROFILE_DIR" ]; then
    echo "[zen-chrome-link] Profile dir $PROFILE_DIR does not exist — skipping."
    exit 0
fi

# Symlink chrome/ into the profile, replacing any existing dir/link
if [ -L "$TARGET_CHROME" ] || [ -e "$TARGET_CHROME" ]; then
    rm -rf "$TARGET_CHROME"
fi
ln -s "$SOURCE_CHROME" "$TARGET_CHROME"
echo "[zen-chrome-link] Linked $TARGET_CHROME -> $SOURCE_CHROME"

# Enable legacy stylesheet support in user.js (created if absent, not overwritten wholesale)
USER_JS="$PROFILE_DIR/user.js"
touch "$USER_JS"

set_pref() {
    local key="$1" val="$2"
    if grep -q "\"$key\"" "$USER_JS" 2>/dev/null; then
        sed -i "s|user_pref(\"$key\".*|user_pref(\"$key\", $val);|" "$USER_JS"
    else
        echo "user_pref(\"$key\", $val);" >> "$USER_JS"
    fi
}

set_pref "toolkit.legacyUserProfileCustomizations.stylesheets" "true"
set_pref "toolkit.legacyUserProfileCustomizations.userContentCSS" "true"

echo "[zen-chrome-link] Prefs set. Restart Zen for changes to take effect."
{{ end -}}
