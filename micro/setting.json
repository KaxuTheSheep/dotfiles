{
    "tabsize": 4,                  // Spaces per tab
    "autoindent": true,             // Keep indentation consistent
    "softwrap": true,               // Wrap long lines
    "cursorline": true,             // Highlight current line
    "mouse": true,                  // Enable mouse clicks
    "colorscheme": "zenburn",       // Default theme (we can change this)
    "statusline": true,             // Show status bar
    "tabstospaces": true,           // Convert tabs to spaces
    "syntax": true                  // Syntax highlighting
}
