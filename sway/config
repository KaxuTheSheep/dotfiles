# Define Mod key
set $mod Mod4

# Set UK keyboard layout
input * {
    xkb_layout gb
}

# Add Wallpaper
exec swaybg -i /home/kaxuthesheep/dotfiles/sway/Wallpaper/Kuromi.jpg -m fill
# Start SwayNC
exec swaync
# Start Waybar
# exec_always --no-startup-id waybar &

# Launch Wofi (desktop apps) with Mod+d
bindsym $mod+d exec wofi --show drun

# Open terminal (Kitty) with Mod+Return
bindsym $mod+Return exec kitty

# Close focused window with Mod+Shift+Q
bindsym $mod+Shift+q kill

# Reload Sway config
bindsym $mod+Shift+c reload

# Exit Sway
bindsym $mod+Shift+e exit

# Optional: move focus (basic directions)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Optional: move windows (basic directions)
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
