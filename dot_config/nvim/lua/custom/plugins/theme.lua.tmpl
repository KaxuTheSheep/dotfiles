return {
  {
    'nvim-mini/mini.nvim',
    priority = 1000,
    config = function()
      {{ if eq .chezmoi.os "linux" }}
      -- Linux: dynamic pywal
      local palette_path = vim.fn.expand('~/.cache/wal/colors-nvim.lua')
      local function load_theme()
        local ok, palette = pcall(dofile, palette_path)
        if not ok then
          vim.notify('Pywal palette not found, run wal first', vim.log.levels.WARN)
          return
        end
        require('mini.base16').setup {
          palette = palette,
          use_cterm = false,
        }
        -- Make background transparent after theme loads
        vim.api.nvim_set_hl(0, 'Normal', { bg = 'NONE' })
        vim.api.nvim_set_hl(0, 'NormalNC', { bg = 'NONE' })
        vim.api.nvim_set_hl(0, 'NormalFloat', { bg = 'NONE' })
      end
      load_theme()

      -- Watcher for live reload
      local watcher = vim.uv.new_fs_event()
      watcher:start(palette_path, {}, function()
        watcher:stop()
        vim.schedule(load_theme)
        vim.defer_fn(function()
          watcher:start(palette_path, {}, function() end)
        end, 200)
      end)
      {{ else }}
      -- Windows: fixed amethyst palette
      local palette = require('windows_palette')
      require('mini.base16').setup {
        palette = palette,
        use_cterm = false,
      }
      -- Make background transparent
      vim.api.nvim_set_hl(0, 'Normal', { bg = 'NONE' })
      vim.api.nvim_set_hl(0, 'NormalNC', { bg = 'NONE' })
      vim.api.nvim_set_hl(0, 'NormalFloat', { bg = 'NONE' })
      {{ end }}

      -- Common mini modules
      require('mini.ai').setup { n_lines = 500 }
      require('mini.surround').setup()
      local statusline = require('mini.statusline')
      statusline.setup { use_icons = vim.g.have_nerd_font }
      statusline.section_location = function() return '%2l:%-2v' end
    end,
  },
}
