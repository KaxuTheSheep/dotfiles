{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.bar.json",
  "monitor": 0,
  "transparency_alpha": 140,
  "max_label_width": 250,
  "font_family": "JetBrains Mono",
  "height": 35,
  "BorderStyle": "Square",
  "widget_spacing": 2,
  "margin": {
    "top": 2,
    "bottom": 2,
    "left": 5,
    "right": 5
  },
  "theme": {
    "palette": "Custom",
    "colours": {
        "base_00": "#110000",  
        "base_01": "#220000",
        "base_02": "#330000",
        "base_03": "#440000",
        "base_04": "#550000",
        "base_05": "#B22222",  
        "base_06": "#FF4400",
        "base_07": "#FF6600",
        "base_08": "#FF0000",
        "base_09": "#FF5500",
        "base_0a": "#FF8800",
        "base_0b": "#CC3300",
        "base_0c": "#FF7700",
        "base_0d": "#FF3300",
        "base_0e": "#FF4400",
        "base_0f": "#FF2200"
    },
    "accent": "Base05",
    "auto_select_fill": "Base01",
    "auto_select_text": "Base05"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": true,
          "click_to_expand": true,
          "max_shown": 1
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": true,
          "show_title_on_hover": true
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Update": {
        "enable": true
      }
    },
    {
      "Media": {
        "enable": true
      }
    },
    {
      "Storage": {
        "enable": true
      }
    },
    {
      "Memory": {
        "enable": true
      }
    },
    {
      "Cpu": {
        "enable": true
      }
    },
    {
      "Network": {
        "enable": false,
        "show_activity": true,
        "show_total_activity": false
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "YearMonthDate"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    },
    {
      "Battery": {
        "enable": false
      }
    }
  ]
}
