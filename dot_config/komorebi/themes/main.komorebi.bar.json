{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.bar.json",
  "monitor": 0,
  "transparency_alpha": 180,
  "max_label_width": 250,
  "font_family": "JetBrains Mono",
  "height": 35,
  "BorderStyle": "Square",
  "widget_spacing": 2,
  "margin": {
    "top": 2,
    "bottom": 2,
    "left": 5,
    "right": 5
  },
  "theme": {
    "palette": "Custom",
    "colours": {
        "base_00": "#11111F",  
        "base_01": "#1C0021",
        "base_02": "#222233",
        "base_03": "#333366",
        "base_04": "#444488",
        "base_05": "#7766FF",  
        "base_06": "#8888FF",
        "base_07": "#9999FF",
        "base_08": "#FF5555",
        "base_09": "#FFAA00",
        "base_0a": "#FFFF00",
        "base_0b": "#00FF00",
        "base_0c": "#00FFFF",
        "base_0d": "#0000FF",
        "base_0e": "#AA00FF",
        "base_0f": "#FF00FF"
    },
    "accent": "Base05",
    "auto_select_fill": "Base01",
    "auto_select_text": "Base05"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": true,
          "click_to_expand": true,
          "max_shown": 1
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": true,
          "show_title_on_hover": true
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Update": {
        "enable": true
      }
    },
    {
      "Media": {
        "enable": true
      }
    },
    {
      "Storage": {
        "enable": true
      }
    },
    {
      "Memory": {
        "enable": true
      }
    },
    {
      "Cpu": {
        "enable": true
      }
    },
    {
      "Network": {
        "enable": false,
        "show_activity": true,
        "show_total_activity": false
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "YearMonthDate"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    },
    {
      "Battery": {
        "enable": false
      }
    }
  ]
}
