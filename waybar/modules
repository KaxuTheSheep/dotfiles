{
"clock#vertical": {
    "format": "  пАЧ  \n  {:%H \n  %M \n  пБ≥  \n%Y \n  %m \n  %d}",
    "interval": 1,
    "tooltip": true,
    "tooltip-format": "{calendar}",
    "calendar": {
        "mode": "year",
        "mode-mon-col": 3,
        "format": {
            "today": "<span color='#e74c3c'>{}</span>"
        }
    }
},
"sway/workspaces": {
	"all-outputs": true,
	"format": "{icon}",
	"format-icons": {
	        "1": "дЄА",
	        "2": "дЇМ",
	        "3": "дЄЙ",
	        "4": "еЫЫ",
	        "5": "дЇФ",
	        "6": "еЕ≠",
		"7": "дЄГ",
	        "8": "еЕЂ",
		"9": "дєЭ",
		"10": "еНБ",
	}
},

"mpris": {
    "interval": 10,
	"format": "{player_icon} ",
	"format-paused": "{status_icon} <i>{dynamic}</i>",
	"on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "smooth-scrolling-threshold": 1,
	"player-icons": {
                "spotify": "пЖЉ",
		"vlc": "у∞ХЉ",
	},
	"status-icons": {
		"paused": "у∞РО",
        "playing": "пБЛ",
        "stopped": "пБН",
	},
	// "ignored-players": ["firefox"]
	"max-length": 30,
},

"tray": {
    "icon-size": 15,
    "spacing": 8,
},

"custom/swaync": {
    "tooltip":true,     
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "пВҐ<span foreground='red'><sup>пСД</sup></span>",
      "none": "пВҐ",
      "dnd-notification": "пЗЈ<span foreground='red'><sup>пСД</sup></span>",
      "dnd-none": "пЗЈ",
      "inhibited-notification": "пВҐ<span foreground='red'><sup>пСД</sup></span>",
      "inhibited-none": "пВҐ",
      "dnd-inhibited-notification": "пЗЈ<span foreground='red'><sup>пСД</sup></span>",
      "dnd-inhibited-none": "пЗЈ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
},

"backlight#vertical": {
	"interval": 2,
    "align": 0.35,
    "rotate": 90,
    "format": "{icon}",
    "format-icons": ["оПХ","оПЦ","оПЧ","оПШ","оПЩ","оПЪ","оПЫ","оПЬ","оПЭ","оПЮ","оПЯ","оП†","оП°","оПҐ","оП£"],
    "on-click": "",
    "on-click-middle": "",
    "on-click-right": "",
    "on-update": "",
    "on-scroll-up": "~/.config/hypr/scripts/Brightness.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/Brightness.sh --dec",
    "smooth-scrolling-threshold": 1,
	"tooltip-format": "{percent}%",
},

"pulseaudio#vertical": {
    "format": "{icon}",
    "format-bluetooth": "у∞В∞",
    "format-muted": "у∞ЦБ",
    "format-icons": {
        "headphone": "пА•",
        "hands-free": "пА•",
        "headset": "пА•",
        "phone": "пВХ",
        "portable": "пВХ",
        "car": "пЖє",
    "default": ["пА¶", "пАІ", "у∞ХЊ", "пА®"],
	"tooltip-format": "{icon} {desc} | {volume}%", 
    "ignored-sinks": ["Easy Effects Sink"],
	},
