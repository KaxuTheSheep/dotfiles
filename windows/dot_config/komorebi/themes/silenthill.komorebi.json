{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 2,
  "default_container_padding": 2,
  "border": true,
  "border_width": 6,
  "border_offset": -2,
  "border_style": "Square",
  "border_implementation": "Komorebi",
  "border_colours": {
    "single": "#B22222",
    "stack": "#CC3300",
    "monocle": "#FF5500",
    "unfocused": "#333333",
    "floating": "#FF8800"
  },
  "animation_enabled": true,
  "animation_duration": 150,
  "animation_style": "EaseInBounce",
  "workspace_count": 10,
  "workspace_window_container_behaviour": "dynamic",
  "mouse_follows_focus": true,
  "ignore_rules": [],
  "session_float_rules": [],
  "global_work_area_offset": [0, 0, 0, 0],
  "monitor_work_area_offset": {},
  "workspace_work_area_offset": {},
  "monitors": [
   {
    "workspaces": [
       { "name": "一", "layout": "Grid" },
       { "name": "二", "layout": "Grid" },
       { "name": "三", "layout": "Grid" },
       { "name": "四", "layout": "Grid" },
       { "name": "五", "layout": "Grid" },
       { "name": "六", "layout": "Grid" },
       { "name": "七", "layout": "Grid" },
       { "name": "八", "layout": "Grid" },
       { "name": "九", "layout": "Grid" },
       { "name": "十", "layout": "Grid" }
     ]
   }
 ]
}
